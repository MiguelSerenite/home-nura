# =============================================================================
# Home Nura — environment variables template
# =============================================================================
#
# Copy this file to `.env.local` and fill in the values. Every `*_TAG_*`
# variable is optional at build time — `lib/products.ts` ships sensible
# defaults so preview deployments don't break — but production should
# override every affiliate tag here so tag rotation never requires a
# code deploy.
#
# Never commit `.env.local` to git. It's ignored by .gitignore.

# -----------------------------------------------------------------------------
# Amazon — Product Advertising API (PA-API v5)
# -----------------------------------------------------------------------------
# Credentials for server-side product fetching via lib/amazon.ts. These
# are the *real* Amazon Associate credentials — treat them like secrets.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=

# -----------------------------------------------------------------------------
# Amazon — affiliate partner tags (per locale)
# -----------------------------------------------------------------------------
# One tag per Amazon marketplace. Used to build outbound affiliate URLs
# in lib/products.ts. Format: "brandname-XX" where XX is the country
# marketplace suffix (21 = EU, 20 = US, etc.).
#
# All six are optional: lib/products.ts falls back to hardcoded defaults
# if a variable is missing, so preview deployments stay functional.
AMAZON_TAG_FR=
AMAZON_TAG_DE=
AMAZON_TAG_EN=
AMAZON_TAG_ES=
AMAZON_TAG_IT=
AMAZON_TAG_NL=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# Phase U ships a first-party RUM pipeline at /api/vitals that needs
# zero third-party config — Web Vitals beacons go straight to the
# server logs for ingestion by a log drain.
#
# If you *also* want cookieless audience analytics, set a Plausible
# domain below and the layout will inject the script. Leave blank to
# disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
